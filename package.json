{
  "name": "cloudgame-hub",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "react-snap",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ functions/ --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:backup": "node scripts/backup-d1.js",
    "deploy": "vite build && wrangler pages deploy dist --project-name=cloudgame-hub"
  },
  "dependencies": {
    "@sentry/react": "^10.0.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.26.0",
    "swiper": "^11.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "critters": "^0.0.25",
    "eslint": "^9.0.0",
    "postcss": "^8.4.47",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.0.0",
    "react-snap": "^1.23.0"
  },
  "reactSnap": {
    "source": "dist",
    "homepage": "/",
    "include": ["/", "/cloud-games", "/cloud-desktops", "/deals", "/library", "/free-games", "/sms-platforms"],
    "skipThirdPartyRequests": true,
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
    "minifyHtml": {
      "collapseWhitespace": true,
      "removeComments": false
    }
  }
}
