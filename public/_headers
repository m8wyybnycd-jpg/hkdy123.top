# Security headers for all pages
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.cloudflare.com; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'

# Cache static assets aggressively (Vite hashed filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache SEO files
/robots.txt
  Cache-Control: public, max-age=86400

/sitemap.xml
  Cache-Control: public, max-age=3600

# Cache OG image
/og-image.svg
  Cache-Control: public, max-age=604800

# Cache favicon
/favicon.svg
  Cache-Control: public, max-age=604800
